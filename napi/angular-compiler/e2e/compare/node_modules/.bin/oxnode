#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/cli/dist/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/cli/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/cli/dist/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/cli/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules/@oxc-node/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/@oxc-node+cli@0.0.35/node_modules:/Users/brooklyn/workspace/github/oxc/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@oxc-node/cli/dist/index.js" "$@"
else
  exec node  "$basedir/../@oxc-node/cli/dist/index.js" "$@"
fi
