{
  "extends": "../../../../../bitwarden-clients/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": false,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext.Disposable"]
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true,
    "enableI18nLegacyMessageIdFormat": false
  },
  "include": ["main.ts", "../../../../../bitwarden-clients/apps/web/src/**/*.ts"],
  "exclude": [
    "../../../../../bitwarden-clients/apps/web/src/**/*.spec.ts",
    "../../../../../bitwarden-clients/apps/web/src/**/*.stories.ts",
    "../../../../../bitwarden-clients/apps/web/src/test.ts"
  ]
}
